<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- JUDUL HALAMAN (Diturunkan dari 32dp menjadi 60dp agar tidak terlalu ke atas) -->
    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Konfirmasi Teks"
        android:textColor="#111111"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- KOTAK ABU-ABU (Tinggi diset proporsional, scrollbar dikonfigurasi eksplisit) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTextContainer"
        android:layout_width="0dp"
        android:layout_height="420dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="#E9ECEF"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle">

        <!-- ScrollView dengan warna track scrollbar custom buatan kita -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:scrollbars="vertical"
            android:scrollbarThumbVertical="@drawable/custom_scrollbar_thumb"
            android:fadeScrollbars="false"
            android:scrollbarSize="6dp">

            <EditText
                android:id="@+id/etScannedResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top|start"
                android:hint="Teks tidak terdeteksi..."
                android:importantForAutofill="no"
                android:inputType="textMultiLine"
                android:lineSpacingMultiplier="1.2"
                android:textColor="#212529"
                android:textSize="15sp" />
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- PETUNJUK EDIT -->
    <TextView
        android:id="@+id/tvHintEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Tap teks untuk mengedit"
        android:textColor="#A0A0A0"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/cardTextContainer"
        app:layout_constraintTop_toBottomOf="@id/cardTextContainer" />

    <!-- CONTAINER TOMBOL -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/tvHintEdit">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnScanAgain"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="0.9"
            android:background="@drawable/bg_btn_secondary"
            android:text="Scan Ulang"
            android:textAllCaps="false"
            android:textColor="#3B82F6"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnExplain"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1.1"
            android:background="@drawable/bg_btn_primary"
            android:text="Jelaskan dengan AI"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>